<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kashira.Editor.ViewModels"
             xmlns:mods="using:Kashira.Core.Mods"
             x:Class="Kashira.Editor.Views.ProjectWorkspaceView"
             x:DataType="vm:ProjectWorkspaceViewModel"
             x:CompileBindings="True">

    <Grid Margin="20" RowDefinitions="Auto,*,Auto">

        <!-- Top bar -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="10" Margin="0,0,0,14">
            <Button Grid.Column="0" Content="← Projects" Command="{Binding BackCommand}"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="8,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding Name}" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource KashiraText}"/>
                <TextBlock Text="{Binding TargetGame}" VerticalAlignment="Center"
                           Foreground="{StaticResource KashiraTextDim}"/>
            </StackPanel>
            <Button Grid.Column="2" Content="Refresh" Command="{Binding RefreshCommand}"/>
            <Button Grid.Column="3" Content="Open Folder" Command="{Binding OpenProjectFolderCommand}"/>
            <Button Grid.Column="4" Content="Build .ktmod" Classes="accent" Command="{Binding BuildCommand}"/>
        </Grid>

        <TabControl Grid.Row="1">

            <!-- Content: 파일 관리자 + 메타 미리보기 -->
            <TabItem Header="Content">
              <DockPanel Margin="0,10,0,0">
                <Expander DockPanel.Dock="Top" Header="＋ Import Kissaki bundle" IsExpanded="True" Margin="0,0,0,10">
                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto,Auto,Auto"
                          Margin="8" ColumnSpacing="8" RowSpacing="6">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Bundle folder" VerticalAlignment="Center"
                                   Foreground="{StaticResource KashiraTextDim}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding BundleDir}" IsReadOnly="True"
                                 PlaceholderText="…\export\DOA6LR\root\RAC_COS_005.g1m"/>
                        <Button Grid.Row="0" Grid.Column="2" Content="Pick folder…" Command="{Binding PickBundleCommand}"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Set name" VerticalAlignment="Center"
                                   Foreground="{StaticResource KashiraTextDim}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding NewSetName}"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Target costume" VerticalAlignment="Center"
                                   Foreground="{StaticResource KashiraTextDim}"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding NewTargetCostume}"
                                 PlaceholderText="(blank = same as source, i.e. re-skin)"/>
                        <Button Grid.Row="3" Grid.Column="2" Content="Import" Classes="accent"
                                Command="{Binding ImportBundleCommand}"/>
                    </Grid>
                </Expander>

                <Grid ColumnDefinitions="*,320" ColumnSpacing="14">
                    <TreeView Grid.Column="0" ItemsSource="{Binding ContentTree}"
                              SelectedItem="{Binding SelectedNode}"
                              Background="{StaticResource KashiraPanel}">
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate x:DataType="mods:ProjectContent+ContentNode"
                                              ItemsSource="{Binding Children}">
                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource KashiraText}"/>
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>

                    <Border Grid.Column="1" Background="{StaticResource KashiraPanel}" CornerRadius="6" Padding="14">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Metadata" FontWeight="SemiBold"
                                       Foreground="{StaticResource KashiraText}" Margin="0,0,0,10"/>
                            <TextBlock DockPanel.Dock="Top" Text="Select an asset to preview."
                                       Foreground="{StaticResource KashiraTextDim}"
                                       IsVisible="{Binding !HasMetadata}"/>
                            <ItemsControl ItemsSource="{Binding Metadata}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="mods:ProjectContent+MetaLine">
                                        <Grid ColumnDefinitions="130,*" Margin="0,0,0,4">
                                            <TextBlock Grid.Column="0" Text="{Binding Key}"
                                                       Foreground="{StaticResource KashiraTextDim}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Value}"
                                                       Foreground="{StaticResource KashiraText}"
                                                       TextWrapping="Wrap"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DockPanel>
                    </Border>
                </Grid>
              </DockPanel>
            </TabItem>

            <!-- Content_Legacy: raw 파일 목록 + 폴더 열기 -->
            <TabItem Header="Content_Legacy">
                <DockPanel Margin="0,10,0,0">
                    <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,10">
                        <TextBlock Text="Drop raw files (0x{ktid}.{ext}) here. They are redirected as-is."
                                   Foreground="{StaticResource KashiraTextDim}"/>
                        <Button Content="Open Content_Legacy Folder" HorizontalAlignment="Left"
                                Command="{Binding OpenLegacyFolderCommand}"/>
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Top" Text="No raw files yet."
                               Foreground="{StaticResource KashiraTextDim}"
                               IsVisible="{Binding !HasLegacy}"/>
                    <ListBox ItemsSource="{Binding LegacyFiles}" Background="{StaticResource KashiraPanel}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="mods:ProjectContent+LegacyFile">
                                <Grid ColumnDefinitions="*,90,80">
                                    <TextBlock Grid.Column="0" Text="{Binding FileName}"
                                               Foreground="{StaticResource KashiraText}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Ext}"
                                               Foreground="{StaticResource KashiraTextDim}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Size}"
                                               Foreground="{StaticResource KashiraTextDim}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </TabItem>
        </TabControl>

        <TextBlock Grid.Row="2" Text="{Binding Status}" Margin="0,12,0,0"
                   Foreground="{StaticResource KashiraTextDim}"/>
    </Grid>
</UserControl>
