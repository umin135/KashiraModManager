<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kashira.Editor.ViewModels"
             xmlns:mods="using:Kashira.Core.Mods"
             x:Class="Kashira.Editor.Views.ProjectWorkspaceView"
             x:DataType="vm:ProjectWorkspaceViewModel"
             x:CompileBindings="True">

    <Grid RowDefinitions="Auto,Auto,*,4,230,Auto" Background="{StaticResource KashiraBg}">

        <!-- File 메뉴 -->
        <Menu Grid.Row="0" Background="{StaticResource KashiraPanel}">
            <MenuItem Header="File">
                <MenuItem Header="Open Project…" Command="{Binding OpenProjectCommand}"/>
                <MenuItem Header="Open Project Folder" Command="{Binding OpenProjectFolderCommand}"/>
                <Separator/>
                <MenuItem Header="Projects (New / Recent)…" Command="{Binding BackToLauncherCommand}"/>
            </MenuItem>
        </Menu>

        <!-- 툴바 -->
        <Border Grid.Row="1" Background="{StaticResource KashiraPanel}" Padding="10,6">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold"
                               VerticalAlignment="Center" Foreground="{StaticResource KashiraText}"/>
                    <Border Background="{StaticResource KashiraPanelHi}" CornerRadius="3" Padding="8,2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding GameStatus}" Foreground="{StaticResource KashiraTextDim}"/>
                    </Border>
                </StackPanel>
                <Button Grid.Column="2" Content="Refresh" Command="{Binding RefreshCommand}"/>
                <Button Grid.Column="3" Content="Open Folder" Command="{Binding OpenProjectFolderCommand}"/>
                <Button Grid.Column="4" Content="Mod Info" ToolTip.Tip="Set author, thumbnail, and preview images">
                    <Button.Flyout>
                        <Flyout Placement="Bottom">
                            <StackPanel Width="360" Spacing="8" Margin="4">
                                <TextBlock Text="Mod Info" FontWeight="SemiBold" Foreground="{StaticResource KashiraText}"/>

                                <TextBlock Text="Author" FontSize="11" Foreground="{StaticResource KashiraTextDim}"/>
                                <TextBox Text="{Binding Author}"/>

                                <TextBlock Text="Description" FontSize="11" Foreground="{StaticResource KashiraTextDim}"/>
                                <TextBox Text="{Binding Description}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="56"/>

                                <TextBlock Text="Thumbnail (thumb.png)" FontSize="11" Foreground="{StaticResource KashiraTextDim}"/>
                                <Grid ColumnDefinitions="96,*" ColumnSpacing="8">
                                    <Border Grid.Column="0" Width="96" Height="96" Background="{StaticResource KashiraBg}" CornerRadius="4">
                                        <Grid>
                                            <Image Source="{Binding Thumbnail}" IsVisible="{Binding HasThumbnail}" Stretch="Uniform" Margin="3"
                                                   RenderOptions.BitmapInterpolationMode="HighQuality"/>
                                            <TextBlock Text="None" IsVisible="{Binding !HasThumbnail}" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" Foreground="{StaticResource KashiraTextDim}"/>
                                        </Grid>
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                                        <Button Content="Choose Image…" HorizontalAlignment="Stretch" Command="{Binding SetThumbnailCommand}"/>
                                        <Button Content="Remove" HorizontalAlignment="Stretch" Command="{Binding ClearThumbnailCommand}"
                                                IsEnabled="{Binding HasThumbnail}"/>
                                    </StackPanel>
                                </Grid>

                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="Preview images (preview/)" FontSize="11" VerticalAlignment="Center"
                                               Foreground="{StaticResource KashiraTextDim}"/>
                                    <Button Grid.Column="1" Content="＋ Add" Command="{Binding AddImageCommand}"/>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding PreviewImages}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:PreviewImageVM">
                                            <StackPanel Width="80" Margin="2" ToolTip.Tip="{Binding Name}">
                                                <Border Width="76" Height="76" Background="{StaticResource KashiraBg}" CornerRadius="4">
                                                    <Image Source="{Binding Thumb}" IsVisible="{Binding HasThumb}" Stretch="Uniform" Margin="3"
                                                           RenderOptions.BitmapInterpolationMode="HighQuality"/>
                                                </Border>
                                                <Button Content="Delete" HorizontalAlignment="Stretch" FontSize="11" Padding="0,1"
                                                        Command="{Binding RemoveCommand}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Button Content="Save" Classes="accent" HorizontalAlignment="Stretch" Command="{Binding SaveModInfoCommand}"/>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>
                <Button Grid.Column="5" Content="Build .ktmod" Classes="accent" Command="{Binding BuildCommand}"
                        ToolTip.Tip="Build a .ktmod into the linked game's _Kashira/Mods"/>
            </Grid>
        </Border>

        <!-- 메인: Outliner(목차) | Viewport | Details -->
        <Grid Grid.Row="2" ColumnDefinitions="240,4,*,4,300">

            <!-- Outliner: 선택 에셋의 목차 -->
            <DockPanel Grid.Column="0" Background="{StaticResource KashiraPanel}">
                <TextBlock DockPanel.Dock="Top" Text="OUTLINER" FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource KashiraTextDim}" Margin="12,8,12,6"/>
                <TextBlock DockPanel.Dock="Top" Text="{Binding CurrentAssetName}" Margin="12,0,12,6"
                           Foreground="{StaticResource KashiraText}" TextTrimming="CharacterEllipsis"/>
                <ListBox ItemsSource="{Binding OutlinerSections}" SelectedItem="{Binding SelectedSection}"
                         Background="Transparent" Margin="4,0,4,4">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:AssetSectionVM">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{Binding Icon, Converter={StaticResource IconKind}}"
                                          Width="15" Height="15" Foreground="{StaticResource KashiraTextDim}"/>
                                <TextBlock Text="{Binding Title}" Foreground="{StaticResource KashiraText}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <GridSplitter Grid.Column="1" Background="{StaticResource KashiraBg}" ResizeDirection="Columns"/>

            <!-- Viewport -->
            <Border Grid.Column="2" Background="{StaticResource KashiraBg}" Padding="12">
                <Grid>
                    <!-- 재질 그리드 -->
                    <DockPanel IsVisible="{Binding HasGrid}">
                        <!-- 변형 추가/삭제(코스튬 단위) + 타겟 CVN 가이드 -->
                        <Border DockPanel.Dock="Top" Background="{StaticResource KashiraPanel}" CornerRadius="4" Padding="10,6" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock Text="Variations" VerticalAlignment="Center" Foreground="{StaticResource KashiraTextDim}"/>
                                <Button Content="−" Command="{Binding RemoveVariationCommand}" ToolTip.Tip="Remove last variation (all materials)" MinWidth="34"/>
                                <Button Content="＋" Command="{Binding AddVariationCommand}" ToolTip.Tip="Add variation (inherited column on all materials)" MinWidth="34"/>
                                <TextBlock Text="{Binding VariationInfo}" VerticalAlignment="Center" Foreground="{StaticResource KashiraText}"/>
                            </StackPanel>
                        </Border>

                        <!-- 셰이더 타입(재질 단위) — install 시 이 재질을 쓰는 메시그룹으로 팬아웃 -->
                        <Border DockPanel.Dock="Top" Background="{StaticResource KashiraPanel}" CornerRadius="4" Padding="10,6" Margin="0,0,0,8"
                                IsVisible="{Binding SelectedGridMaterial.CanEditShader}">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <TextBlock Grid.Column="0" Text="Shader" VerticalAlignment="Center" Foreground="{StaticResource KashiraTextDim}"
                                           ToolTip.Tip="Shader type for this material. Applied on install to every mesh sharing this material."/>
                                <ComboBox Grid.Column="1" ItemsSource="{Binding SelectedGridMaterial.ShaderOptions}"
                                          SelectedItem="{Binding SelectedGridMaterial.SelectedShader}"
                                          HorizontalAlignment="Stretch" Padding="6,2" MinHeight="26">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ShaderChoiceVM">
                                            <TextBlock Text="{Binding Display}" Foreground="#d8b26a"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <Border DockPanel.Dock="Top" Background="{StaticResource KashiraPanel}" CornerRadius="4" Padding="10,7" Margin="0,0,0,10">
                            <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SelectedCellInfo}" Foreground="{StaticResource KashiraText}"/>
                                    <TextBlock Text="Select a g1t in the Content browser, then 'Assign'" FontSize="11"
                                               Foreground="{StaticResource KashiraTextDim}"/>
                                </StackPanel>
                                <Border Grid.Column="1" Background="#5a2d2d" CornerRadius="3" Padding="8,3" VerticalAlignment="Center"
                                        IsVisible="{Binding SelectedGridMaterial.MissingAlbedo}"
                                        ToolTip.Tip="cat 1 missing (assumed base texture)">
                                    <TextBlock Text="⚠ cat 1" Foreground="#ffb3a7"/>
                                </Border>
                                <Button Grid.Column="2" Content="Assign" Classes="accent" Command="{Binding AssignSelectedCellCommand}"/>
                                <Button Grid.Column="3" Content="Clear" Command="{Binding ClearSelectedCellCommand}"/>
                            </Grid>
                        </Border>

                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                      DataContext="{Binding SelectedGridMaterial}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="96" Height="26"/>
                                    <ItemsControl ItemsSource="{Binding ColumnHeaders}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="x:String">
                                                <Border Width="96" Height="26">
                                                    <TextBlock Text="{Binding}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               FontWeight="SemiBold" Foreground="{StaticResource KashiraTextDim}"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                                <ItemsControl ItemsSource="{Binding Rows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:GridRowVM">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <Border Width="96" Height="96">
                                                    <TextBlock Text="{Binding Role}" VerticalAlignment="Center" Foreground="{StaticResource KashiraText}"/>
                                                </Border>
                                                <ItemsControl ItemsSource="{Binding Cells}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:GridCellVM">
                                                            <Button Classes="cell" Click="OnCellClick" Width="96" Height="96" Margin="0,0,4,0"
                                                                    ToolTip.Tip="{Binding Tooltip}">
                                                                <Grid>
                                                                    <Border Background="{StaticResource KashiraBg}" CornerRadius="4"/>
                                                                    <Image Source="{Binding Thumb}" Stretch="Uniform" Margin="4"
                                                                           IsVisible="{Binding HasThumb}"
                                                                           RenderOptions.BitmapInterpolationMode="HighQuality"/>
                                                                    <TextBlock Text="{Binding Glyph}" IsVisible="{Binding !HasThumb}"
                                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                               FontSize="20" Foreground="{StaticResource KashiraTextDim}"/>
                                                                    <Border IsVisible="{Binding IsSelected}" CornerRadius="4"
                                                                            BorderBrush="{StaticResource KashiraAccent}" BorderThickness="3"/>
                                                                </Grid>
                                                            </Button>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>

                    <!-- 텍스처 프리뷰 -->
                    <DockPanel IsVisible="{Binding HasPreview}">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8"
                                    HorizontalAlignment="Center" Margin="0,0,0,8">
                            <Button Content="Export DDS" Command="{Binding ExportDdsCommand}"/>
                            <Button Content="Export TGA" Command="{Binding ExportTgaCommand}"/>
                            <Button Content="Replace…" Classes="accent" Command="{Binding ReplaceTextureCommand}"/>
                        </StackPanel>
                        <TextBlock DockPanel.Dock="Bottom" Text="{Binding CurrentAssetName}" HorizontalAlignment="Center"
                                   Margin="0,8,0,0" Foreground="{StaticResource KashiraTextDim}"/>
                        <Image Source="{Binding PreviewImage}" Stretch="Uniform"
                               RenderOptions.BitmapInterpolationMode="HighQuality"/>
                    </DockPanel>

                    <!-- g1m 섹션(raw export/import + 0x10003 재질 타입) -->
                    <DockPanel IsVisible="{Binding HasG1mSection}">
                        <!-- 섹션 raw export/import 바 -->
                        <Border DockPanel.Dock="Top" Background="{StaticResource KashiraPanel}" CornerRadius="4" Padding="10,7" Margin="0,0,0,10">
                            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding G1mSectionInfo}" Foreground="{StaticResource KashiraText}" FontWeight="SemiBold"/>
                                    <TextBlock Text="Export/import raw section .bin (same size = safe)"
                                               FontSize="11" Foreground="{StaticResource KashiraTextDim}"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Export .bin" Command="{Binding ExportG1mSectionCommand}"/>
                                <Button Grid.Column="2" Content="Import .bin…" Command="{Binding ImportG1mSectionCommand}"/>
                            </Grid>
                        </Border>

                        <!-- 0x10008: 서브메시 분석(읽기 전용) -->
                        <DockPanel IsVisible="{Binding HasSubmeshList}">
                            <Grid DockPanel.Dock="Top" ColumnDefinitions="64,52,54,52,84,84,72" Margin="4,0,4,4">
                                <TextBlock Grid.Column="0" Text="Submesh" FontWeight="SemiBold" Foreground="{StaticResource KashiraTextDim}"/>
                                <TextBlock Grid.Column="1" Text="VB" FontWeight="SemiBold" Foreground="{StaticResource KashiraTextDim}"/>
                                <TextBlock Grid.Column="2" Text="vsize" FontWeight="SemiBold" Foreground="{StaticResource KashiraTextDim}"/>
                                <TextBlock Grid.Column="3" Text="Mat" FontWeight="SemiBold" Foreground="{StaticResource KashiraTextDim}"/>
                                <TextBlock Grid.Column="4" Text="Verts" FontWeight="SemiBold" Foreground="{StaticResource KashiraTextDim}"/>
                                <TextBlock Grid.Column="5" Text="Tris" FontWeight="SemiBold" Foreground="{StaticResource KashiraTextDim}"/>
                                <TextBlock Grid.Column="6" Text="Cloth" FontWeight="SemiBold" Foreground="{StaticResource KashiraTextDim}"/>
                            </Grid>
                            <ScrollViewer>
                                <ItemsControl ItemsSource="{Binding Submeshes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:SubmeshRowVM">
                                            <Grid ColumnDefinitions="64,52,54,52,84,84,72" Margin="0,0,0,3">
                                                <TextBlock Grid.Column="0" Text="{Binding Sub}" Foreground="{StaticResource KashiraText}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Vb}" Foreground="{StaticResource KashiraTextDim}"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Vsize}" Foreground="{StaticResource KashiraTextDim}"/>
                                                <TextBlock Grid.Column="3" Text="{Binding Mat}" Foreground="{StaticResource KashiraTextDim}"/>
                                                <TextBlock Grid.Column="4" Text="{Binding Verts}" Foreground="{StaticResource KashiraText}"/>
                                                <TextBlock Grid.Column="5" Text="{Binding Tris}" Foreground="{StaticResource KashiraText}"/>
                                                <TextBlock Grid.Column="6" Text="{Binding Cloth}" Foreground="#d8b26a"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>

                        <!-- 0x10009: 메시 구조 인스펙터(읽기전용). 셰이더 편집은 재질 그리드에서. 슬롯 클릭 → 텍스처 그리드. -->
                        <DockPanel IsVisible="{Binding HasMeshList}">
                            <TextBlock DockPanel.Dock="Bottom" Margin="4,6,4,0" FontSize="11" Foreground="{StaticResource KashiraTextDim}"
                                       Text="Read-only structure view. Click a slot (mat N) to jump to that material's texture grid. Edit shaders in the material grid."/>
                            <Grid DockPanel.Dock="Top" ColumnDefinitions="100,56,180,*" Margin="4,0,4,4">
                                <TextBlock Grid.Column="0" Text="Mesh" FontWeight="SemiBold" Foreground="{StaticResource KashiraTextDim}"/>
                                <TextBlock Grid.Column="1" Text="Type" FontWeight="SemiBold" Foreground="{StaticResource KashiraTextDim}"/>
                                <TextBlock Grid.Column="2" Text="Slots" FontWeight="SemiBold" Foreground="{StaticResource KashiraTextDim}"/>
                                <TextBlock Grid.Column="3" Text="Shader" FontWeight="SemiBold" Foreground="{StaticResource KashiraTextDim}"/>
                            </Grid>
                            <ScrollViewer>
                                <ItemsControl ItemsSource="{Binding Meshes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:MeshRowVM">
                                            <Grid ColumnDefinitions="100,56,180,*" Margin="0,0,0,3">
                                                <TextBlock Grid.Column="0" Text="{Binding Hash}" Foreground="{StaticResource KashiraText}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Type}" Foreground="{StaticResource KashiraTextDim}" VerticalAlignment="Center"/>
                                                <Grid Grid.Column="2" VerticalAlignment="Center">
                                                    <TextBlock Text="-" Foreground="{StaticResource KashiraTextDim}" IsVisible="{Binding !HasSlots}"/>
                                                    <ItemsControl ItemsSource="{Binding SlotChips}" IsVisible="{Binding HasSlots}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:SlotChipVM">
                                                                <Button Command="{Binding OpenCommand}" Content="{Binding Label}"
                                                                        Padding="6,2" Margin="0,0,4,4" FontSize="11"
                                                                        ToolTip.Tip="Click to jump to this material's texture grid"/>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Grid>
                                                <TextBlock Grid.Column="3" Text="{Binding ShaderDisplay}" Foreground="#9a8f7a"
                                                           VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>

                        <!-- 0x10003: 재질 타입(nMtrID) 편집 -->
                        <DockPanel IsVisible="{Binding HasG1mProps}">
                            <Border DockPanel.Dock="Top" Background="{StaticResource KashiraPanel}" CornerRadius="4" Padding="10,7" Margin="0,0,0,10">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Material type (nMtrID)" Foreground="{StaticResource KashiraText}" FontWeight="SemiBold"/>
                                        <TextBlock Text="Replaces the value only (size unchanged). Changing the type may require separate shader properties/textures."
                                                   FontSize="11" Foreground="{StaticResource KashiraTextDim}"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Apply" Classes="accent" Command="{Binding ApplyG1mTypesCommand}"/>
                                </Grid>
                            </Border>
                            <ScrollViewer>
                                <ItemsControl ItemsSource="{Binding G1mMaterials}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:G1mMaterialVM">
                                            <Grid ColumnDefinitions="120,*,220" Margin="0,0,0,6" ColumnSpacing="10">
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"
                                                           Foreground="{StaticResource KashiraText}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Info}" VerticalAlignment="Center"
                                                           Foreground="{StaticResource KashiraTextDim}"/>
                                                <ComboBox Grid.Column="2" ItemsSource="{Binding Options}"
                                                          SelectedItem="{Binding SelectedType}" HorizontalAlignment="Stretch">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:NMtrOption">
                                                            <TextBlock Text="{Binding Label}"/>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </DockPanel>

                    <!-- 안내 -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                        <StackPanel.IsVisible>
                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                <Binding Path="!HasGrid"/>
                                <Binding Path="!HasPreview"/>
                                <Binding Path="!HasG1mSection"/>
                            </MultiBinding>
                        </StackPanel.IsVisible>
                        <TextBlock Text="Select an asset in the Content browser." HorizontalAlignment="Center"
                                   Foreground="{StaticResource KashiraTextDim}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="3" Background="{StaticResource KashiraBg}" ResizeDirection="Columns"/>

            <!-- Details: 선택 목차 항목의 상세 -->
            <DockPanel Grid.Column="4" Background="{StaticResource KashiraPanel}">
                <TextBlock DockPanel.Dock="Top" Text="DETAILS" FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource KashiraTextDim}" Margin="12,8,12,6"/>
                <TextBlock DockPanel.Dock="Top" Text="Select an item in the outliner." Margin="12,0,12,0"
                           Foreground="{StaticResource KashiraTextDim}" IsVisible="{Binding !HasDetails}"/>
                <ScrollViewer Padding="12,4,12,12">
                    <ItemsControl ItemsSource="{Binding Details}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="mods:ProjectContent+MetaLine">
                                <Grid ColumnDefinitions="130,*" Margin="0,0,0,4">
                                    <TextBlock Grid.Column="0" Text="{Binding Key}" Foreground="{StaticResource KashiraTextDim}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Value}" Foreground="{StaticResource KashiraText}" TextWrapping="Wrap"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Grid>

        <GridSplitter Grid.Row="3" Background="{StaticResource KashiraBg}" ResizeDirection="Rows" HorizontalAlignment="Stretch"/>

        <!-- Content Browser: 폴더 트리 | 항목 그리드 -->
        <Grid Grid.Row="4" Background="{StaticResource KashiraPanel}" RowDefinitions="Auto,*">
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto,Auto" Margin="10,7,10,4" ColumnSpacing="8">
                <TextBlock Grid.Column="0" Text="CONTENT BROWSER" FontSize="11" FontWeight="Bold"
                           VerticalAlignment="Center" Foreground="{StaticResource KashiraTextDim}"/>
                <Button Grid.Column="3" Content="＋ Import Bundle" Classes="accent"
                        IsVisible="{Binding ContentEnabled}" ToolTip.Tip="Import Kissaki bundle (Content/ authoring — currently on hold)">
                    <Button.Flyout>
                        <Flyout Placement="Top">
                            <StackPanel Width="340" Spacing="8" Margin="4">
                                <TextBlock Text="Import Kissaki bundle" FontWeight="SemiBold"
                                           Foreground="{StaticResource KashiraText}"/>
                                <TextBlock Text="Set name" FontSize="11" Foreground="{StaticResource KashiraTextDim}"/>
                                <TextBox Text="{Binding NewSetName}"/>
                                <TextBlock Text="Target costume (leave empty to match source)" FontSize="11"
                                           Foreground="{StaticResource KashiraTextDim}"/>
                                <TextBox Text="{Binding NewTargetCostume}"
                                         PlaceholderText="e.g. RAC_COS_001"/>
                                <Button Content="Choose bundle folder &amp; import…" Classes="accent"
                                        HorizontalAlignment="Stretch" Command="{Binding ImportBundleCommand}"/>
                                <TextBlock Text="{Binding BundleDir}" FontSize="11"
                                           Foreground="{StaticResource KashiraTextDim}" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>
            </Grid>

            <Grid Grid.Row="1" ColumnDefinitions="260,4,*">
                <!-- 폴더 트리(폴더만) -->
                <TreeView Grid.Column="0" ItemsSource="{Binding FolderTree}" SelectedItem="{Binding SelectedFolder}"
                          Background="{StaticResource KashiraBg}" Margin="6,0,0,6">
                    <TreeView.ItemTemplate>
                        <TreeDataTemplate x:DataType="mods:ProjectContent+ContentNode" ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <PathIcon Data="{Binding Converter={StaticResource IconKind}, ConverterParameter=folder}"
                                          Width="14" Height="14" Foreground="#d8b26a"/>
                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource KashiraText}"/>
                            </StackPanel>
                        </TreeDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>

                <GridSplitter Grid.Column="1" Background="{StaticResource KashiraPanel}" ResizeDirection="Columns"/>

                <!-- 폴더 직속 항목 그리드 -->
                <ListBox Grid.Column="2" ItemsSource="{Binding FolderItems}" SelectedItem="{Binding SelectedBrowserItem}"
                         DoubleTapped="OnBrowserActivate"
                         Background="{StaticResource KashiraBg}" Margin="6,0,6,6"
                         ToolTip.Tip="Double-click: open folder / select asset">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:BrowserItemVM">
                            <StackPanel Width="96" Margin="2" ToolTip.Tip="{Binding Kind}">
                                <Border Width="88" Height="88" Background="{StaticResource KashiraPanel}" CornerRadius="4">
                                    <Grid>
                                        <Image Source="{Binding Thumb}" IsVisible="{Binding HasThumb}" Stretch="Uniform" Margin="4"
                                               RenderOptions.BitmapInterpolationMode="HighQuality"/>
                                        <!-- 폴더: 아이콘 -->
                                        <PathIcon Data="{Binding Icon, Converter={StaticResource IconKind}}" Width="38" Height="38"
                                                  IsVisible="{Binding IsDirectory}" Foreground="#d8b26a"/>
                                        <!-- 파일(썸네일 없음): 3글자 대문자 타입 배지 -->
                                        <Border IsVisible="{Binding ShowBadge}" CornerRadius="4"
                                                Background="{StaticResource KashiraBg}" BorderBrush="#4a4034" BorderThickness="1"
                                                Padding="10,5" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Badge}" FontSize="22" FontWeight="Bold"
                                                       FontFamily="Consolas, monospace" Foreground="#d8b26a"/>
                                        </Border>
                                    </Grid>
                                </Border>
                                <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" TextAlignment="Center"
                                           MaxWidth="88" Foreground="{StaticResource KashiraText}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>

        <!-- 상태바 -->
        <Border Grid.Row="5" Background="{StaticResource KashiraPanel}" Padding="12,6">
            <TextBlock Text="{Binding Status}" Foreground="{StaticResource KashiraTextDim}"/>
        </Border>
    </Grid>
</UserControl>
