<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Kashira.Editor.App"
             xmlns:local="using:Kashira.Editor"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <!-- 아이콘 키 → Geometry 변환기(자체 벡터, 무의존) -->
        <local:IconKindConverter x:Key="IconKind"/>

        <!-- Kashira 테마 팔레트 (Manager와 공유 톤) -->
        <SolidColorBrush x:Key="KashiraBg" Color="#3d3d4c"/>
        <SolidColorBrush x:Key="KashiraPanel" Color="#34343f"/>
        <SolidColorBrush x:Key="KashiraPanelHi" Color="#45455670"/>
        <SolidColorBrush x:Key="KashiraAccent" Color="#c0392b"/>
        <SolidColorBrush x:Key="KashiraAccentHover" Color="#d24636"/>
        <SolidColorBrush x:Key="KashiraText" Color="#e8e8ee"/>
        <SolidColorBrush x:Key="KashiraTextDim" Color="#a0a0ad"/>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <Style Selector="Button">
            <Setter Property="Background" Value="{StaticResource KashiraPanel}"/>
            <Setter Property="Foreground" Value="{StaticResource KashiraText}"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="Button.accent">
            <Setter Property="Background" Value="{StaticResource KashiraAccent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource KashiraAccentHover}"/>
        </Style>

        <!-- 재질 그리드 셀 버튼(플랫) -->
        <Style Selector="Button.cell">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="Button.cell:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource KashiraPanelHi}"/>
        </Style>
    </Application.Styles>
</Application>
