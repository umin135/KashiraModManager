<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kashira.Gui.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="720" d:DesignHeight="480"
             x:Class="Kashira.Gui.Views.LauncherView"
             x:DataType="vm:LauncherViewModel">

    <DockPanel Margin="18">

        <!-- Update available banner -->
        <Border DockPanel.Dock="Top" IsVisible="{Binding UpdateAvailable}"
                Background="{StaticResource KashiraAccent}" CornerRadius="5"
                Padding="12,8" Margin="0,0,0,10">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding UpdateText}" Foreground="White"
                           VerticalAlignment="Center" TextWrapping="Wrap"/>
                <Button Grid.Column="1" Content="Update" Command="{Binding UpdateCommand}"
                        Background="White" Foreground="{StaticResource KashiraAccent}" FontWeight="SemiBold"/>
            </Grid>
        </Border>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="14" Margin="4,2,4,12">
            <Image Source="/Assets/logo.png" Width="54" Height="54" VerticalAlignment="Center"/>
            <StackPanel Spacing="2" VerticalAlignment="Center">
                <TextBlock Text="{Binding Title}" Foreground="{StaticResource KashiraAccent}"
                           FontSize="30" FontWeight="Bold"/>
                <TextBlock Text="{Binding Subtitle}" Foreground="{StaticResource KashiraTextDim}" FontSize="13"/>
            </StackPanel>
        </StackPanel>

        <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,Auto,Auto,Auto,Auto" Margin="0,12,0,0">
            <Button Grid.Column="0" Classes="accent" HorizontalAlignment="Left"
                    Content="Scan for games" Command="{Binding ScanCommand}"/>
            <Button Grid.Column="2" Content="Remove" Command="{Binding RemoveCommand}" Margin="8,0,0,0"/>
            <Button Grid.Column="3" Content="New" Command="{Binding NewCommand}" Margin="8,0,0,0"/>
            <Button Grid.Column="4" Classes="accent" Content="Select"
                    Command="{Binding SelectCommand}" Margin="8,0,0,0"/>
        </Grid>

        <TextBlock DockPanel.Dock="Bottom" Text="{Binding Status}"
                   Foreground="{StaticResource KashiraTextDim}" FontSize="12" Margin="4,10,4,0"/>

        <Border Background="{StaticResource KashiraPanel}" CornerRadius="6" Padding="4">
            <ListBox ItemsSource="{Binding Games}" SelectedItem="{Binding SelectedGame}"
                     Background="Transparent">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:GameItemViewModel">
                        <Grid ColumnDefinitions="Auto,*" Margin="4,7">
                            <Panel Grid.Column="0" Width="40" Height="40" Margin="2,0,12,0">
                                <Image Source="{Binding Icon}" IsVisible="{Binding HasIcon}"
                                       Stretch="Uniform" Width="40" Height="40"/>
                                <Border IsVisible="{Binding !HasIcon}"
                                        Background="{StaticResource KashiraPanelHi}" CornerRadius="6">
                                    <TextBlock Text="{Binding InitialLetter}" Foreground="{StaticResource KashiraText}"
                                               FontSize="18" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Panel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource KashiraText}"
                                           FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding InstallPath}" Foreground="{StaticResource KashiraTextDim}"
                                           FontSize="11" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

    </DockPanel>
</UserControl>
