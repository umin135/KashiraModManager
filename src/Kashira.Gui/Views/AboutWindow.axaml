<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Kashira.Gui.Views.AboutWindow"
        Width="460" Height="400" CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource KashiraBg}"
        Icon="/Assets/kashira.ico"
        Title="About Kashira">

    <Window.Styles>
        <Style Selector="Button.link">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
        <Style Selector="Button.link:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Window.Styles>

    <StackPanel Margin="26,22" Spacing="12">

        <!-- Title + version -->
        <StackPanel Orientation="Horizontal" Spacing="14">
            <Image Source="/Assets/logo.png" Width="56" Height="56" VerticalAlignment="Center"/>
            <StackPanel VerticalAlignment="Center" Spacing="1">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Kashira" Foreground="{StaticResource KashiraAccent}"
                               FontSize="26" FontWeight="Bold"/>
                    <TextBlock x:Name="VersionText" Foreground="{StaticResource KashiraTextDim}"
                               FontSize="13" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                </StackPanel>
                <TextBlock Text="Katana Engine Universal Mod Manager"
                           Foreground="{StaticResource KashiraTextDim}" FontSize="12"/>
            </StackPanel>
        </StackPanel>

        <Border Height="1" Background="{StaticResource KashiraPanelHi}" Margin="0,4"/>

        <TextBlock Text="Developer: UMIN" Foreground="{StaticResource KashiraText}" FontSize="13"/>

        <TextBlock Foreground="{StaticResource KashiraText}" FontSize="13" TextWrapping="Wrap"
                   Text="If you're experiencing problems or need help, please join our Discord Server."/>

        <Border Height="1" Background="{StaticResource KashiraPanelHi}" Margin="0,4"/>

        <!-- Links -->
        <Button Classes="link" Tag="https://github.com/umin135/KashiraModManager" Click="OnLinkClick">
            <TextBlock Text="GitHub" Foreground="{StaticResource KashiraAccent}" FontWeight="SemiBold" FontSize="14"/>
        </Button>

        <Button Classes="link" Tag="https://discord.gg/jwaB8zhb9v" Click="OnLinkClick">
            <TextBlock Text="Discord Server" Foreground="{StaticResource KashiraAccent}" FontWeight="SemiBold" FontSize="14"/>
        </Button>

        <Button Content="Close" Classes="accent" HorizontalAlignment="Right"
                Margin="0,8,0,0" Click="OnCloseClick"/>
    </StackPanel>
</Window>
